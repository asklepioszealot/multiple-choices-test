{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Çoktan Seçmeli Sorular",
  "version": "0.1.0",
  "identifier": "com.asklepioszealot.multiplechoicestest",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost",
    "beforeBuildCommand": "node build.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Çoktan Seçmeli Sorular",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
